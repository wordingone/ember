# sha-bearing artifacts: bytes are load-bearing (manifest_sha256 in receipts,
# shard sha256 chains). git must NEVER rewrite line endings at checkout.
corpus-manifests/** -text
receipts/** -text
tokenizer/** -text
# research/ holds raw-byte-pinned premises (fp26_prereg pins the decision
# artifact's sha256 over exact on-disk bytes); CRLF normalization on Windows
# checkouts drifts those bytes and fails the prereg premise. Pin -text (eng-47).
research/** -text
# ledger views + probe sets are sha-bound by audit receipts (sp-3/fp-28 bind
# byte-true sha256); CRLF conversion on fresh checkouts drifts the bytes vs
# the recorded sha. Pin -text (same class as the eng-47 research/** pin).
ledger/** -text
probes/** -text
# scripts and hooks: enforce LF (prevents CRLF creep on Windows checkouts)
*.sh text eol=lf
*.py text eol=lf
